{
  "wallpaperDirs": ["$HOME/Pictures/wallpapers"],
  "cacheDir": "$HOME/.cache/wallpaper_thumbs",
  "showBgPreview": true,
  "previewStyle": "carousel",
  "debugMode": false,

  "carousel": {
    "itemWidth": 450,
    "itemHeight": 320,
    "spacing": 25,
    "rotation": 40,
    "perspective": 0.3
  },

  "animation": {
    "scrollDuration": 280,
    "scrollContinueInterval": 230,
    "bgSlideDuration": 250,
    "bgParallaxFactor": 40
  },

  "appearance": {
    "showBorderGlow": true,
    "showShadow": true,
    "bgOverlayOpacity": 0.4
  }
}
